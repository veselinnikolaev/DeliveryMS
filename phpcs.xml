<?xml version="1.0"?>
<ruleset name="DeliveryMS">
    <description>PSR-12 for DeliveryMS with project-specific tweaks.</description>

    <file>Core</file>
    <file>App</file>
    <file>config</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/web/*</exclude-pattern>

    <rule ref="PSR12"/>

    <!-- Views are HTML templates, not PHP class files -->
    <rule ref="PSR12.Files.FileHeader">
        <exclude-pattern>*/Views/*</exclude-pattern>
    </rule>

    <!-- Allow longer lines in view/template files -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
        <exclude-pattern>*/Views/*</exclude-pattern>
    </rule>
</ruleset>