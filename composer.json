{
    "name": "veselinnikolaev/deliveryms",
    "description": "Delivery Management System",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-mysqli": "*",
        "vlucas/phpdotenv": "^5.5",
        "phpmailer/phpmailer": "^6.9",
        "tecnickcom/tcpdf": "^6.7",
        "shuchkin/simplexlsxgen": "^1.4",
      "ext-gd": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "Core/",
            "App\\": "App/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist"
    }
}